# File: .env.local.example

# ========================================
# QuantPips Environment Variables
# ========================================

# FX Rates API (to be configured in Phase 6)
# Example: exchangerate.host, openexchangerates.org, etc.
NEXT_PUBLIC_FX_API_URL=
FX_API_KEY=

# Feature Flags (for development/testing)
# Set to "true" to enable premium features for all users
NEXT_PUBLIC_PREMIUM_ENABLED=true

# App URL (used for metadata, og tags, etc.)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Firebase Configuration
   
NEXT_PUBLIC_FIREBASE_API_KEY=
   
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
   
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
   
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
   
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
  
NEXT_PUBLIC_FIREBASE_APP_ID=
   
NEXT_PUBLIC_FIREBASE_SYNC_ENABLED=true